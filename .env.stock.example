# Stock Management Subdomain - Environment Variables
# Copy to .env.local for local development or add to Netlify environment variables

# ============ Deployment & App Config ============
NEXT_PUBLIC_APP_TYPE=stock
NEXT_PUBLIC_REQUIRE_AUTH=true
NEXT_PUBLIC_INTERNAL_ONLY=true
NEXT_PUBLIC_URL=https://stock.yourdomain.com

# ============ Database (Neon PostgreSQL) ============
# Get from Netlify env vars (auto-added) or Neon console
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# ============ Better Auth (required) ============
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
BETTER_AUTH_URL=https://stock.yourdomain.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://stock.yourdomain.com

# At least one provider must be configured
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# UI login link provider default
NEXT_PUBLIC_BETTER_AUTH_SOCIAL_PROVIDER=google

# ============ Internal Access Control ============
# Comma-separated list of emails allowed to access stock system
# CRITICAL: Only internal team members should be listed here
ALLOWED_INTERNAL_EMAILS=your-email@company.com,manager@company.com

# ============ Optional: Audit Logging ============
# Send audit logs to external service (optional)
# AUDIT_LOG_ENDPOINT=https://logs.example.com/api/audit
# AUDIT_LOG_API_KEY=your-api-key

# ============ Optional: Stripe (if stock system needs payments) ============
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_abc123
# STRIPE_SECRET_KEY=sk_test_abc123

# ============ Optional: Monitoring & Analytics (internal only) ============
# SENTRY_DSN=https://your-sentry-dsn
# POSTHOG_API_KEY=your-posthog-key

# ============ GitHub (for future data sync, optional) ============
# GITHUB_TOKEN=ghp_your-token
# GITHUB_REPO_OWNER=shivamgif
# GITHUB_REPO_NAME=hanumantmarble
